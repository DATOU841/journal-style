{
  "schema": "journal_style_workflow_states_v1",
  "_note": "Machine-readable state machine for the journal-style runner. Each step declares entry conditions, required inputs, produced artifacts, governing gate, and next step. The runner advances strictly in order; a step cannot be entered until its prerequisite step is gate-verified. Steps without a gate cannot be marked satisfied_by_prior_run (P6 iron rule).",
  "authoritative_state_file": "current-run-state.json",
  "run_modes": {
    "full": {
      "paths": ["common", "metadata", "fulltext", "scoring"],
      "description": "Single formal path. Requires MinerU/mu fulltext pack, metadata evidence as an intermediate layer, per-article profiles, aggregation, calibrated scoring, and provenance-gated handoff."
    }
  },
  "read_only_mirrors": [
    "task-state.json",
    "05-handoff/wenheng-center-status.json"
  ],
  "steps": [
    {
      "id": "step00_material_intake",
      "name": "Step 0 material intake manifest",
      "entry": [
        "task_skeleton_exists"
      ],
      "requires_inputs": [],
      "produces": [
        "00-intake/material-intake-manifest.json"
      ],
      "gate": "material-intake",
      "next": "step01_init",
      "paths": ["common"],
      "resume_skippable": false,
      "_skip_note": "Has gate; may be satisfied only if manifest passes material-intake gate with current sha."
    },
    {
      "id": "step01_init",
      "name": "Step 1 init task",
      "entry": [
        "step00_material_intake.satisfied"
      ],
      "requires_inputs": [
        "00-intake/material-intake-manifest.json"
      ],
      "produces": [
        "00-intake/task-init.json"
      ],
      "gate": null,
      "next": "step02_identity",
      "paths": ["common"],
      "resume_skippable": false,
      "_skip_note": "Produces a non-mirror init receipt (task-init.json), NOT task-state.json. No gate -> cannot be auto-skipped via resume; must be re-run."
    },
    {
      "id": "step02_identity",
      "name": "Step 2 journal identity confirmation",
      "entry": [
        "step01_init.satisfied"
      ],
      "requires_inputs": [
        "00-intake/material-intake-manifest.json"
      ],
      "produces": [
        "00-official/journal-identity-confirmation.md",
        "00-official/journal-official-and-web-evidence.md"
      ],
      "gate": null,
      "next": "step03_title_intake",
      "paths": ["common"],
      "resume_skippable": false
    },
    {
      "id": "step03_title_intake",
      "name": "Step 3 full title intake",
      "entry": [
        "step02_identity.satisfied"
      ],
      "requires_inputs": [
        "00-intake/material-intake-manifest.json"
      ],
      "produces": [
        "01-title-intake/journal-full-title-list.xlsx",
        "01-title-intake/journal-title-ingestion-log.md"
      ],
      "gate": null,
      "next": "step04_title_screening",
      "paths": ["common"],
      "resume_skippable": false
    },
    {
      "id": "step04_title_screening",
      "name": "Step 4 title screening",
      "entry": [
        "step03_title_intake.satisfied"
      ],
      "requires_inputs": [
        "01-title-intake/journal-full-title-list.xlsx"
      ],
      "produces": [
        "015-title-screening/title-screening-ledger.json",
        "06-gates/title-screening-gate.json"
      ],
      "gate": null,
      "next": "step05_topic_library",
      "paths": ["common"],
      "resume_skippable": false
    },
    {
      "id": "step05_topic_library",
      "name": "Step 5 topic special library",
      "entry": [
        "step04_title_screening.satisfied"
      ],
      "requires_inputs": [
        "015-title-screening/title-screening-ledger.json"
      ],
      "produces": [
        "02-topic-library/topic-special-library-plan.md",
        "02-topic-library/topic-related-title-list.xlsx"
      ],
      "gate": null,
      "next": "step06_zotero_pdf_rag",
      "paths": ["common"],
      "resume_skippable": false
    },
    {
      "id": "step06_zotero_pdf_rag",
      "name": "Step 6 Zotero/PDF/RAG verification",
      "entry": [
        "step05_topic_library.satisfied"
      ],
      "requires_inputs": [
        "02-topic-library/topic-related-title-list.xlsx",
        "025-rag-import/zotero-pdf-rag-handoff-input.json"
      ],
      "produces": [
        "025-rag-import/zotero-pdf-rag-handoff-input.json"
      ],
      "gate_input": "025-rag-import/zotero-pdf-rag-handoff-input.json",
      "gate": "zotero-pdf-rag-handoff",
      "next": "step07_core_library",
      "paths": ["common"],
      "resume_skippable": true,
      "_skip_note": "External jiansuo-ruku work. May be satisfied_by_prior_run ONLY if handoff artifact passes zotero-pdf-rag-handoff gate with current sha."
    },
    {
      "id": "step07_core_library",
      "name": "Step 7 core library selection",
      "entry": [
        "step06_zotero_pdf_rag.satisfied"
      ],
      "requires_inputs": [
        "015-title-screening/title-screening-ledger.json",
        "06-gates/zotero-pdf-rag-handoff.json"
      ],
      "produces": [
        "02b-core-library/core-library-ledger.json",
        "02b-core-library/core-library-rejected.json"
      ],
      "gate": "core-library-selection",
      "next": "step07b_mu_fulltext_pack",
      "paths": ["common"],
      "resume_skippable": true
    },
    {
      "id": "step07b_mu_fulltext_pack",
      "name": "Step 7b MinerU/mu fulltext core pack acceptance",
      "entry": [
        "step07_core_library.satisfied"
      ],
      "requires_inputs": [
        "02b-core-library/core-library-ledger.json",
        "03-analysis/fulltext-layer/mu-fulltext-core-pack.json"
      ],
      "produces": [
        "03-analysis/fulltext-layer/mu-fulltext-core-pack.json"
      ],
      "gate": "mu-fulltext-pack",
      "next": "step08a_metadata_layer",
      "paths": ["fulltext"],
      "resume_skippable": true,
      "_boundary": "MinerU/mu pack is produced upstream by 检索入库; journal-style only validates and analyzes the complete text pack."
    },
    {
      "id": "step08a_metadata_layer",
      "name": "Step 8a metadata-layer analysis",
      "entry": [
        "step07_core_library.satisfied"
      ],
      "requires_inputs": [
        "02b-core-library/core-library-ledger.json"
      ],
      "produces": [
        "03-analysis/metadata-layer/",
        "03-analysis/metadata-layer/abstract-metadata-ledger.jsonl"
      ],
      "gate_input": "03-analysis/metadata-layer/abstract-metadata-ledger.jsonl",
      "gate": "abstract-metadata-ledger",
      "next": "step08b1_per_article_profile",
      "paths": ["metadata"],
      "resume_skippable": true
    },
    {
      "id": "step08b1_per_article_profile",
      "name": "Step 8b1 per-article fulltext style profiles",
      "entry": [
        "step08a_metadata_layer.satisfied"
      ],
      "requires_inputs": [
        "03-analysis/fulltext-layer/mu-fulltext-core-pack.json"
      ],
      "produces": [
        "03-analysis/fulltext-layer/per-article-style-profiles.json"
      ],
      "gate": "per-article-profile-complete",
      "next": "step08b_fulltext_layer",
      "paths": ["fulltext"],
      "resume_skippable": false
    },
    {
      "id": "step08b_fulltext_layer",
      "name": "Step 8b fulltext-layer aggregation",
      "entry": [
        "step08b1_per_article_profile.satisfied"
      ],
      "requires_inputs": [
        "03-analysis/fulltext-layer/per-article-style-profiles.json"
      ],
      "produces": [
        "03-analysis/fulltext-layer/journal-style-aggregation-bundle.json",
        "03-analysis/fulltext-layer/journal-rag-fulltext-pattern-report.md",
        "03-analysis/fulltext-layer/journal-method-material-report.md",
        "03-analysis/fulltext-layer/journal-argument-style-report.md",
        "03-analysis/fulltext-layer/journal-reference-ecology-report.md",
        "03-analysis/fulltext-layer/journal-reference-network-report.md"
      ],
      "gate": "aggregation-threshold",
      "next": "step09b_scoring_calibration",
      "paths": ["fulltext"],
      "resume_skippable": false
    },
    {
      "id": "step09b_scoring_calibration",
      "name": "Step 9b published-sample scoring replay calibration",
      "entry": [
        "step08b_fulltext_layer.satisfied"
      ],
      "requires_inputs": [
        "03-analysis/fulltext-layer/journal-style-aggregation-bundle.json"
      ],
      "produces": [
        "04-fit-evaluation/journal-fit-scoring-model.json"
      ],
      "gate": "scoring-replay-calibrated",
      "next": "step09_fit",
      "paths": ["scoring"],
      "resume_skippable": false
    },
    {
      "id": "step09_fit",
      "name": "Step 9 submission fit scoring",
      "entry": [
        "step09b_scoring_calibration.satisfied"
      ],
      "requires_inputs": [
        "03-analysis/fulltext-layer/journal-style-aggregation-bundle.json",
        "04-fit-evaluation/journal-fit-scoring-model.json"
      ],
      "produces": [
        "04-fit-evaluation/submission-fit-score.md"
      ],
      "gate_input": "04-fit-evaluation/journal-fit-scoring-model.json",
      "gate": "submission-fit-ready",
      "next": "step10_handoff",
      "paths": ["scoring"],
      "resume_skippable": false
    },
    {
      "id": "step10_handoff",
      "name": "Step 10 topic suggestion and handoff",
      "entry": [
        "step09_fit.satisfied"
      ],
      "requires_inputs": [
        "04-fit-evaluation/submission-fit-score.md",
        "04-fit-evaluation/journal-fit-scoring-model.json",
        "03-analysis/fulltext-layer/journal-style-aggregation-bundle.json"
      ],
      "produces": [
        "04-fit-evaluation/topic-suggestion-report.md",
        "04-fit-evaluation/target-journal-decision.md",
        "05-handoff/journal-polish-consumption-pack.json",
        "05-handoff/handoff-to-downstream-skills.md",
        "05-handoff/wenheng-center-status.json"
      ],
      "gate": "provenance-required",
      "next": null,
      "paths": ["scoring"],
      "resume_skippable": false
    }
  ]
}
